# For running this service STANDALONE (outside Docker).
# In Docker, compose injects these from social-media-deploy/env/backend-fastapi.env instead.
DATABASE_URL=postgresql+asyncpg://social:social_dev_password@localhost:5432/social_fastapi
JWT_SECRET_KEY=change-me-fastapi-dev-secret
JWT_ACCESS_TTL_MIN=15
JWT_REFRESH_TTL_DAYS=7
CODE_TTL_MINUTES=10
ENV=dev
NOTIFIER=console
CORS_ORIGINS=http://localhost:3000
